# Home Hub — Environment Configuration
# Copy to .env and fill in your values

# Home Assistant
HASS_URL=http://homeassistant.local:8123
HASS_TOKEN=<your-long-lived-access-token>

# Alternative: HA auth storage path (for auto-refresh token flow)
# HASS_AUTH_STORAGE=/path/to/homeassistant/.storage/auth

# Default vacuum entity ID
VACUUM_ENTITY=vacuum.your_vacuum

# TTS broadcast script (default: apple-homepod-control skill)
# HUB_TTS_SCRIPT=/path/to/tts_to_homepod.py
